        
     
     <main class="page-content">     
        <section class="section-30 section-md-50">
          <div class="container">
             
              <div class="cell-md-8 cell-sm-10">
                  <section class="text-left">
                      <h6 class="text-bold">PERSONAL INFORMATION&nbsp;&nbsp;>&nbsp;&nbsp;<em style="color:brown"><%= data.bio.fname !== undefined ? (data.bio.fname+' '+data.bio.mname+' '+data.bio.lname).toUpperCase() : ''; %> <%= data.bio.staff_no !== undefined ? '( STAFF NUMBER : '+data.bio.staff_no+' )':'' %> - <%- (data.bio.staff_group == 'SM'? ' SENIOR MEMBER ' : (data.bio.staff_group == 'SS' ? ' SENIOR STAFF ':' JUNIOR STAFF '))%></em></b></h6>
                      <div class="text-subline"></div><br><br>
                      <%= data.bio.fname %>
                  <form name="formstaff" method="post" action="/hrm/poststaff" enctype="multipart/form-data">
                      <div class="range offset-top-7">
                        <div class="cell-sm-3">
                          <div class="form-group">
                            <label class="form-label form-label-outside" for="gender">Gender</label>
                            <select class="form-control" id="gender" name="gender">
                                <option>Choose Gender</option>
                              <option value="M" <%= data.bio.gender == 'M' ? 'selected="selected"':'' %>>Male</option>
                              <option value="F" <%= data.bio.gender == 'F' ? 'selected="selected"':'' %>>Female</option>
                            </select>                                
                          </div>
                        </div>
                        <div class="cell-sm-9 offset-top-17 offset-sm-top-0">
                          <div class="range">
                            <div class="cell-sm-4">
                              <div class="form-group">
                                <label class="form-label form-label-outside rd-input-label" for="fname">First Name</label>
                                <input class="form-control form-control-has-validation form-control-last-child" id="fname" type="text" name="fname" value="<%= data.bio.fname %>" data-constraints="@Required"><span class="form-validation"></span>
                              </div>
                            </div>
                            <div class="cell-sm-4 offset-top-17 offset-sm-top-0">
                              <div class="form-group">
                                <label class="form-label form-label-outside rd-input-label" for="mname">Middle Name(s)</label>
                                <input class="form-control form-control-has-validation form-control-last-child" id="mname" type="text" name="mname" value="<%= data.bio.mname %>" data-constraints="@Required"><span class="form-validation"></span>
                              </div>
                            </div>
                            <div class="cell-sm-4 offset-top-17 offset-sm-top-0">
                                <div class="form-group">
                                  <label class="form-label form-label-outside rd-input-label" for="lname">Last Name</label>
                                  <input class="form-control form-control-has-validation form-control-last-child" id="lname" type="text" name="lname" value="<%= data.bio.lname %>" data-constraints="@Required"><span class="form-validation"></span>
                                </div>
                            </div>
                          </div>
                        </div>
                      </div>

                      <!-- Line 2 -->
                      <div class="range offset-top-17">                          
                          <div class="cell-sm-12 offset-top-17 offset-sm-top-0">
                            <div class="range">
                              <div class="cell-sm-3">
                                  <div class="form-group">
                                    <label class="form-label form-label-outside rd-input-label" for="dob">Date of Birth</label>
                                    <input class="form-control form-control-has-validation form-control-last-child" id="dob" type="date" name="dob" value="<%= data.bio.dobx %>" data-constraints="@Required"><span class="form-validation"></span>
                                  </div>
                              </div>
                              <div class="cell-sm-3">
                                <div class="form-group">
                                  <label class="form-label form-label-outside rd-input-label" for="birth_place">Place of Birth</label>
                                  <input class="form-control form-control-has-validation form-control-last-child" id="birth_place" type="text" name="birth_place" value="<%= data.bio.birth_place %>" data-constraints="@Required"><span class="form-validation"></span>
                                </div>
                              </div>
                              <div class="cell-sm-3 offset-top-17 offset-sm-top-0">
                                <div class="form-group">
                                  <label class="form-label form-label-outside rd-input-label" for="hometown">Home Town</label>
                                  <input class="form-control form-control-has-validation form-control-last-child" id="hometown" type="text" name="hometown" value="<%= data.bio.hometown %>" data-constraints="@Required"><span class="form-validation"></span>
                                </div>
                              </div>
                              <div class="cell-sm-3 offset-top-17 offset-sm-top-0">
                                  <div class="form-group">
                                    <label class="form-label form-label-outside rd-input-label" for="district">District</label>
                                    <input class="form-control form-control-has-validation form-control-last-child" id="district" type="text" name="district" value="<%= data.bio.district %>" data-constraints="@Required"><span class="form-validation"></span>
                                  </div>
                              </div>
                            </div>
                          </div>
                        </div>


                         <!-- Line 3 -->
                      <div class="range offset-top-17">                          
                          <div class="cell-sm-12 offset-top-17 offset-sm-top-0">
                            <div class="range">
                              <div class="cell-sm-3">
                                  <div class="form-group">
                                    <label class="form-label form-label-outside rd-input-label" for="region">Region</label>
                                    <input class="form-control form-control-has-validation form-control-last-child" id="region" type="text" name="region" value="<%= data.bio.region %>" data-constraints="@Required"><span class="form-validation"></span>
                                  </div>
                              </div>
                              <div class="cell-sm-3">
                                <div class="form-group">
                                  <label class="form-label form-label-outside rd-input-label" for="country">Nationality</label>
                                  <input class="form-control form-control-has-validation form-control-last-child" id="country" type="text" name="country" value="<%= data.bio.country %>"  data-constraints="@Required"><span class="form-validation"></span>
                                </div>
                              </div>
                              <div class="cell-sm-3 offset-top-17 offset-sm-top-0">
                                <div class="form-group">
                                  <label class="form-label form-label-outside rd-input-label" for="phone">Phone</label>
                                  <input class="form-control form-control-has-validation form-control-last-child" id="phone" type="integer" name="phone" value="<%= data.bio.phone %>" data-constraints="@Required @IsNumeric"><span class="form-validation"></span>
                                </div>
                              </div>
                              <div class="cell-sm-3 offset-top-17 offset-sm-top-0">
                                  <div class="form-group">
                                    <label class="form-label form-label-outside rd-input-label" for="email">E-mail Address</label>
                                    <input class="form-control form-control-has-validation form-control-last-child" id="email" type="email" name="email" value="<%= data.bio.email %>" data-constraints="@Required @Email"><span class="form-validation"></span>
                                  </div>
                              </div>
                            </div>
                          </div>
                        </div>

                        <!-- Line 4 -->
                        <div class="offset-top-17">
                            <div class="form-group">
                              <label class="form-label form-label-outside rd-input-label" for="address">Home Address</label>
                              <textarea class="form-control form-control-has-validation form-control-last-child" id="address" name="address" data-constraints="@Required" style="height: 100px;"><%= data.bio.address %></textarea><span class="form-validation"></span>
                            </div>
                        </div>


                             <!-- Line 7 -->
                           <div class="range offset-top-17">                          
                              <div class="cell-sm-12 offset-top-17 offset-sm-top-0">
                                <div class="range">
                                  <div class="cell-sm-4">
                                      <div class="form-group">
                                        <label class="form-label form-label-outside" for="mstatus">Marital Status</label>
                                        <select class="form-control" name="mstatus">
                                            <option value="">Choose Marital Status</option>
                                            <option value="SINGLE" <%= data.bio.mstatus == 'SINGLE' ? 'selected="selected"':'' %>>Single</option>
                                            <option value="MARRIED" <%= data.bio.mstatus == 'MARRIED' ? 'selected="selected"':'' %>>Married</option>
                                        </select>                                
                                      </div>
                                  </div>
                                                           
                                </div>
                              </div>
                            </div>
                          

                          <br><br><h6 class="text-bold">PERSONAL DOCUMENTS</h6>
                          <div class="text-subline"></div>


                           <!-- Line 10 -->
                         <div class="range offset-top-17">                          
                            <div class="cell-sm-12 offset-top-17 offset-sm-top-0">
                              <div class="range">
                                  <div class="cell-sm-3">
                                      <div class="form-group">
                                          <!-- CV-->                                       
                                          <label class="form-label form-label-outside rd-input-label">Curriculum Vitae (CV) <em><small>( PDF only )</small></em></label>
                                          <%  let i = 1;
                                           data.doc.map((cert,i) =>{ if(cert.category == 'CV'){
                                              if(i == 1){
                                            %>
                                            <%- '<i class="fa fa-check fa-lg" style="position:relative;bottom:-45px;color:green;"></i>' %>
                                            <%   } i++;}
                                              }); 
                                            %>
                                          <input name="cv_cert" id="cert" type="file"  class="form-control form-control-has-validation form-control-last-child">                                  
                                      </div>
                                  </div>
                                <div class="cell-sm-3">
                                    <div class="form-group">
                                        <!-- CERTIFICATES-->                                       
                                        <label class="form-label form-label-outside rd-input-label" >Marriage Certificate(s) <em><small>( PDF only )</small></em></label>
                                        <%   i = 1;
                                        data.doc.map((cert,i) =>{ if(cert.category == 'MARITAL'){
                                           if(i == 1){
                                        %>
                                        <%- '<i class="fa fa-check fa-lg" style="position:relative;bottom:-45px;color:green;"></i>' %>
                                        <%   } i++;}
                                          }); 
                                        %>
                                        <input name="ma_cert" id="cert" type="file"  class="form-control form-control-has-validation form-control-last-child">                                         
                                    </div>
                                </div>
                                <div class="cell-sm-3">
                                    <div class="form-group">
                                        <!-- BIRTH-->                                       
                                        <label class="form-label form-label-outside rd-input-label" for="acad_qualification">Birth Certificate <em><small>( PDF only )</small></em></label>
                                        <%  i = 1;
                                        data.doc.map((cert,i) =>{ if(cert.category == 'BIRTH'){
                                           if(i == 1){
                                        %>
                                        <%- '<i class="fa fa-check fa-lg" style="position:relative;bottom:-45px;color:green;"></i>' %>
                                        <%   } i++;}
                                          }); 
                                        %>
                                        <input name="birth_cert" id="cert" type="file"  class="form-control form-control-has-validation form-control-last-child">                                         
                                    </div>
                                </div> 
                                
                                <div class="cell-sm-3">
                                  <div class="form-group">
                                    <!-- BIRTH-->
                                    <label class="form-label form-label-outside rd-input-label" for="acad_qualification">Medical Reports<em>
                                        <small>( One PDF File only )</small>
                                      </em>
                                    </label>
                                       <%  i = 1;
                                           data.doc.map((cert,i) =>{ if(cert.category == 'MEDICAL'){
                                              if(i == 1){
                                       %>
                                       <%- '<i class="fa fa-check fa-lg" style="position:relative;bottom:-45px;color:green;"></i>' %>
                                       <%   } i++;}
                                         }); 
                                       %>
                                          <input name="medic_cert" id="cert" type="file"  class="form-control form-control-has-validation form-control-last-child">
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>
                          

                        <br><br><h6 class="text-bold">UNIVERSITY INFORMATION</h6>
                        <div class="text-subline"></div>
                        <div class="data2">                    
                          
                                <!-- Line 1 -->
                                <div class="range offset-top-17">                          
                                    <div class="cell-sm-12 offset-top-17 offset-sm-top-0">
                                      <div class="range">
                                        <div class="cell-sm-3">
                                            <div class="form-group">
                                              <label class="form-label form-label-outside rd-input-label" for="letter">Appointment Letter</label>
                                                <%  i = 1;
                                                  if(data.appoints != null){
                                                    data.appoints.map((cert,i) =>{ 
                                                       if(i == 1){
                                                %>
                                                <%- '<i class="fa fa-check fa-lg" style="position:relative;bottom:-45px;color:green;"></i>' %>
                                                <%     } i++;
                                                    });
                                                  }                                                 
                                                 %>
                                              <input class="form-control form-control-has-validation form-control-last-child" id="appoint_cert" type="file" name="appoint_cert" value=""/>
                                             
                                            </div>
                                        </div>
                                        <div class="cell-sm-3">
                                            <div class="form-group">
                                              <label class="form-label form-label-outside rd-input-label" for="ssnit">SSNIT Number</label>
                                              <input class="form-control form-control-has-validation form-control-last-child" id="ssnit" type="text" name="ssnit" value="<%= data.bio.ssnit %>"/>
                                            </div>
                                        </div>
                                        <div class="cell-sm-3 offset-top-17 offset-sm-top-0">
                                          <div class="form-group">
                                            <label class="form-label form-label-outside rd-input-label" for="ucc_mail">University E-Mail</label>
                                            <input class="form-control form-control-has-validation form-control-last-child" id="ucc_mail" type="text" name="ucc_mail" value="<%= data.bio.ucc_mail %>" />
                                          </div>
                                        </div>
                                        <div class="cell-sm-3 offset-top-17 offset-sm-top-0">
                                            <div class="form-group">
                                              <label class="form-label form-label-outside rd-input-label" for="staffno">Staff Number</label>
                                              <input class="form-control form-control-has-validation form-control-last-child" readonly="readonly" id="staff_no" type="text" name="staff_no" value="<%= data.bio.staff_no %>"/>
                                            </div>
                                        </div>
                                      </div>
                                    </div>
                                  </div>


                                    <!-- Line 2 -->
                                <div class="range offset-top-17">                          
                                    <div class="cell-sm-12 offset-top-17 offset-sm-top-0">
                                      <div class="range">                                        
                                        <div class="cell-sm-3">
                                          <div class="form-group">
                                            <label class="form-label form-label-outside rd-input-label" for="job_id">Current Job Title/Role</label>
                                            <select name="job_id" class="form-control">
                                                <option value="">Select Job Title</option>
                                              <%  data.jobs.map((job,i) =>{ %>
                                                <option value="<%= job.id%>" <%- job.id == data.bio.job_id ? 'selected="selected"': '' %>>
                                                  <%= job.title%>
                                                </option>
                                                <%   }); %>
                                            </select>
                                          </div>
                                        </div>
                                        <div class="cell-sm-3">
                                          <div class="form-group">
                                            <label class="form-label form-label-outside rd-input-label" for="unit_id">Current Section/Unit</label>
                                            <select name="unit_id" class="form-control">
                                              <option value="">Select Section/Unit</option>
                                              <%  data.units.map((unit,i) =>{ %>
                                                <option value="<%= unit.id%>" <%- unit.id == data.bio.unit_id ? 'selected="selected"': '' %>>
                                                  <%= unit.short_name%>
                                                </option>
                                                <%   }); %>
                                            </select>
                                          </div>
                                        </div>
                                        <div class="cell-sm-3">
                                          <div class="form-group">
                                            <label class="form-label form-label-outside rd-input-label" for="scale_id">Current Grade / Scale</label>
                                            <select name="scale_id" class="form-control">
                                              <option value="">Select Grade/Scale</option>
                                              <%  data.scales.map((scale,i) =>{ %>
                                                <option value="<%= scale.id%>" <%- scale.id == data.bio.scale_id ? 'selected="selected"': '' %>>
                                                  <%= scale.title +', Step '+scale.notch%>
                                                </option>
                                                <%   }); %>
                                            </select>
                                          </div>
                                        </div>
                                        <div class="cell-sm-3">
                                          <div class="form-group">
                                            <label class="form-label form-label-outside rd-input-label" for="staff_group">Staff Membership Group</label>
                                            <select name="staff_group" class="form-control" readonly="readonly">
                                              <option value="JS" <%- 'JS'==data.bio.staff_group ? 'selected="selected"': '' %>>Junior Staff</option>
                                              <option value="SS" <%- 'SS'==data.bio.staff_group ? 'selected="selected"': '' %>>Senior Staff</option>
                                              <option value="SM" <%- 'SM'==data.bio.staff_group ? 'selected="selected"': '' %>>Senior Member</option>
                                            </select>
                                          </div>
                                        </div>
                                      </div>
                                    </div>
                                  </div>


                        </div>
                        <br><div class="text-subline"></div><br>



                        <div class="offset-top-25">
                             <button class="btn btn-primary btn-2x" type="submit" onclick="return confirm('Do you want to Submit?');">SAVE</button>
                              <% if(data.bio.id > 0){ %>
                              <a href="javascript:history.back();" onclick="return confirm('Cancel?')" class="btn">CANCEL</a>
                              <% }else{ %>
                              <a href="javascript:window.close();" onclick="return confirm('Cancel?')" class="btn">CANCEL</a>
                              <% } %>
                                <input name="staff" type="hidden" value="<%= data.bio.staff_no || 0 %>" />
                             <input name="id" type="hidden" value="<%= data.bio.id || 0 %>" />
                             <input name="appoint_id" type="hidden" value="<%= data.bio.appoint_id || 0 %>" />
                        </div>
                       <hr/>

                       </form>

                    </section>
              </div>
          </div>
        </section>
        
      </main>
      